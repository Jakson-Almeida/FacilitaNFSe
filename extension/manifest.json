{
  "manifest_version": 3,
  "name": "FacilitaNFSe",
  "version": "0.1.0",
  "description": "Preenche formulários do Emissor Nacional NFS-e com templates salvos localmente.",
  "permissions": ["storage"],
  "host_permissions": ["https://www.nfse.gov.br/*"],
  "action": {
    "default_title": "FacilitaNFSe",
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.nfse.gov.br/EmissorNacional/DPS/*"],
      "js": [
        "shared/constants.js",
        "shared/dates.js",
        "shared/steps.js",
        "shared/storage.js",
        "content/dom-helpers.js",
        "templates/defaults.js",
        "content/fill-pessoas.js",
        "content/fill-servico.js",
        "content/fill-tributacao.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
