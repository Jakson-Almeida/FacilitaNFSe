{
  "manifest_version": 3,
  "name": "FacilitaNFSe",
  "version": "0.3.0",
  "description": "Preenche formulários do Emissor Nacional NFS-e com templates salvos localmente.",
  "permissions": ["storage"],
  "host_permissions": ["https://www.nfse.gov.br/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "FacilitaNFSe",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.nfse.gov.br/EmissorNacional/DPS/*"],
      "css": ["content/panel.css"],
      "js": [
        "shared/constants.js",
        "shared/dates.js",
        "shared/template-utils.js",
        "shared/steps.js",
        "shared/storage.js",
        "content/dom-helpers.js",
        "templates/defaults.js",
        "content/step-fields.js",
        "content/fill-pessoas.js",
        "content/fill-servico.js",
        "content/fill-tributacao.js",
        "content/template-editor.js",
        "content/panel.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
